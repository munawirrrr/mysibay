	"eventHandlers": [
		{
			"eventId": "EVENT_BEFOREADD",
			"pageType": "add",
			"code": "date_default_timezone_set(\"Asia/Jakarta\");\n$values[\"tahun\"] = date('Y');\n\n$values[\"status\"] = 'belum disetujui';\n\n\n\n// =======================\n// 1. Buat Folder\n// =======================\n\n$npsn = preg_replace('/[^A-Za-z0-9_\\-]/', '_', $values[\"npsn\"]);\n$tahun    = preg_replace('/[^0-9]/', '', $values[\"tahun\"]);\n\n\n$folderName = \"files/\".$npsn.\"_\".$tahun;\n\nif (!is_dir(getabspath($folderName))) {\n    mkdir(getabspath($folderName), 0777, true);\n}\n\n// =======================\n// 2. Field Upload\n// =======================\n\n$uploadFields = array(\"file_sptjm\");\n\nforeach($uploadFields as $field)\n{\n    if(!empty($values[$field]))\n    {\n        $fileArray = my_json_decode($values[$field]);\n\n        for($i = 0; $i < count($fileArray); $i++)\n        {\n            $oldPath = $fileArray[$i][\"name\"];\n\n            // Format nama file: kolom_semester_tahun.pdf\n            $newFileName = $folderName.\"/\".$npsn.\"_\".$tahun.\"_sptjm_kepala.pdf\";\n\n            // Jika sudah ada file lama, hapus\n            if(file_exists(getabspath($newFileName))) {\n                unlink(getabspath($newFileName));\n            }\n\n            rename(getabspath($oldPath), getabspath($newFileName));\n\n            $fileArray[$i][\"name\"] = $newFileName;\n        }\n\n        $values[$field] = my_json_encode($fileArray);\n    }\n}\nreturn true;"
		},
		{
			"eventId": "EVENT_RECORD_EDITABLE",
			"code": "if (Security::getUserGroup()==\"Sispendik\" and $values[\"status\"] !=\"belum disetujui\") {\n                $isEditable = false;\n            } else {\n                $isEditable = true;\n        }\n        \n        \n        return $isEditable;"
		},
		{
			"eventId": "EVENT_JS_ONLOAD",
			"pageType": "list",
			"code": "this.on('afterInlineEdit', function( fieldsData ) {\n                       location.reload();\n                } )\n\n// Place event code here.\n// Use \"Add Action\" button to add code snippets."
		},
		{
			"eventId": "EVENT_JS_ONLOAD",
			"pageType": "add",
			"code": "this.on('beforeSave', function(formObj, fieldControlsArr, pageObj){\n\n    var url = \"https://drive.google.com/file/d/1nfWLtGyFJYrJm-3g1JLQA5ue9Nbm4dHl/view\";\n\n    if (confirm('Pastikan SPTJM yang diupload sudah sesuai format.\\n\\nKlik OK jika sudah sesuai.\\nKlik Cancel untuk melihat format contoh.')){\n\n        return true;\n\n    } else {\n\n        window.open(url, '_blank'); // buka link di tab baru\n        Runner.delDisabledClass(pageObj.saveButton);\n        return false;\n\n    }\n\n});"
		}
	],
